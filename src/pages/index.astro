---
import BaseLayout from '../layouts/BaseLayout.astro';

const navCards = [
  {
    href: '/about',
    label: 'About',
    description: 'Who I am and why any of this exists.',
  },
  {
    href: '/career',
    label: 'Career',
    description: '6+ years in enterprise IT.',
  },
  {
    href: '/now',
    label: 'Now',
    description: "What I'm currently playing, watching, obsessing over.",
  },
  {
    href: '/contact',
    label: 'Contact',
    description: "Say something. I don't bite.",
  },
];
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="relative mb-10">
    <div class="hero-inner">
      <div class="hero-accent-bar" aria-hidden="true"></div>
      <div class="hero-text">
        <p class="hero-greeting">hi, I'm</p>
        <h1 class="hero-name">
          <span class="hero-name-ghost">Ben</span>
          <span class="hero-name-fill">Atkins</span>
        </h1>
        <p class="text-xl leading-relaxed mb-4" style="color: var(--color-body);">
          IT Support &amp; SysAdmin.
          <br /><br />
          Humanist at heart. Gamer by nature. Fueled by indie music and the outdoors. Perpetually fascinated by psychology. Occasional photographer.
        </p>
      </div>
    </div>
  </section>

  <!-- Gradient divider -->
  <div class="gradient-divider mb-10" aria-hidden="true"></div>

  <script>
    const quotes = [
      "The present moment is the only moment available to us, and it is the door to all moments. — Thich Nhat Hanh",
      "Almost everything will work again if you unplug it for a few minutes, including you. — Anne Lamott",
      "Within you, there is a stillness and a sanctuary to which you can retreat at any time. — Hermann Hesse",
      "Do not dwell in the past, do not dream of the future, concentrate the mind on the present moment. — Buddha",
      "The quieter you become, the more you are able to hear. — Rumi",
      "Breathe. Let go. And remind yourself that this very moment is the only one you know you have for sure. — Oprah Winfrey",
      "Peace comes from within. Do not seek it without. — Buddha",
      "In the middle of difficulty lies opportunity. — Albert Einstein",
      "You are the sky. Everything else is just the weather. — Pema Chödrön",
      "Nothing is worth more than this day. — Goethe",
      "Wherever you are, be all there. — Jim Elliot",
      "One small crack does not mean that you are broken; it means that you were put to the test and you didn't fall apart. — Linda Poindexter",
      "Slow down and everything you are chasing will come around and catch you. — John De Paola",
      "Life is available only in the present moment. — Thich Nhat Hanh",
      "Tension is who you think you should be. Relaxation is who you are. — Chinese Proverb",
    ];

    const el = document.getElementById('mindfulness-quote');
    let current = Math.floor(Math.random() * quotes.length);

    function showQuote(index) {
      if (!el) return;
      el.style.opacity = '0';
      setTimeout(() => {
        el.textContent = quotes[index];
        el.style.opacity = '1';
      }, 600);
    }

    showQuote(current);
    setInterval(() => {
      current = (current + 1) % quotes.length;
      showQuote(current);
    }, 12000);
  </script>

  <!-- Nav cards -->
  <section class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
    {navCards.map(card => (
      <a href={card.href} class="nav-card group">
        <span class="nav-card-label">
          {card.label} <span class="arrow">→</span>
        </span>
        <span class="nav-card-desc">{card.description}</span>
      </a>
    ))}
  </section>

  <!-- Quote -->
  <p id="mindfulness-quote" class="mb-10" style="color: var(--color-muted); transition: opacity 0.6s ease; min-height: 1.5em;">
    &nbsp;
  </p>

  <!-- Gradient divider -->
  <div class="gradient-divider mb-10" aria-hidden="true"></div>

  <!-- Photo banner -->
  <section class="photo-banner-wrap">
    <img src="/images/home/gc1.jpg" alt="Horseshoe Bend, Arizona" class="photo-banner" />
    <p class="photo-caption">Horseshoe Bend, Arizona, 2026</p>
  </section>
</BaseLayout>

<style>
  /* Hero layout — left-aligned with accent bar */
  .hero-inner {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .hero-accent-bar {
    flex-shrink: 0;
    width: 3px;
    align-self: stretch;
    background: linear-gradient(180deg, #93c5fd 0%, #2563eb 50%, #1e3a8a 100%);
    border-radius: 999px;
    opacity: 0.8;
  }

  .hero-text {
    flex: 1;
    text-align: left;
  }

  /* "hi, I'm" inline greeting */
  .hero-greeting {
    font-size: 1rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  /* Giant name — ghost + fill split */
  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 10vw, 5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    display: block;
  }

  .hero-name-ghost {
    -webkit-text-stroke: 2px #93c5fd;
    color: transparent;
    margin-right: 0.2em;
  }

  .hero-name-fill {
    background: linear-gradient(135deg, #93c5fd 0%, #2563eb 45%, #1e3a8a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Thin gradient line between hero and cards */
  .gradient-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-accent) 50%, transparent 100%);
    opacity: 0.45;
  }

  /* Nav cards */
  .nav-card {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.35rem 1.25rem;
    background: var(--color-surface);
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s, transform 0.2s ease, box-shadow 0.25s;
  }

  /* Gradient sheen on hover */
  .nav-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(140deg, rgba(124, 58, 237, 0.1) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.25s;
  }

  .nav-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 10px 36px rgba(124, 58, 237, 0.22);
  }

  .nav-card:hover::before {
    opacity: 1;
  }

  .nav-card-label {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 0.4rem;
    transition: color 0.2s;
    position: relative;
  }

  .nav-card:hover .nav-card-label {
    color: var(--color-accent-light);
  }

  .arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .nav-card:hover .arrow {
    transform: translateX(5px);
  }

  .nav-card-desc {
    display: block;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-muted);
    position: relative;
  }

  /* Photo banner */
  .photo-banner-wrap {
    width: 100%;
  }

  .photo-banner {
    width: 100%;
    height: 380px;
    object-fit: cover;
    object-position: center;
    border-radius: 14px;
    border: 1px solid var(--color-border);
    display: block;
  }

  .photo-caption {
    margin-top: 0.6rem;
    text-align: right;
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }

  @media (max-width: 480px) {
    .photo-banner {
      height: 220px;
    }
  }
</style>
