---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  'Identity & Access Management',
  'M365 / Azure',
  'Endpoint Management',
  'PowerShell',
  'SOC 2',
  'Hardware Deployment',
  'Front-End Dev',
];

const passions = [
  {
    label: 'Gaming',
    body: 'Souls-likes, Metroidvanias, JRPGs — and Rocket League perpetually in the background. Genuinely passionate about game design, mechanical innovation, and clean UX.',
  },
  {
    label: 'Music',
    body: "Indie rock, pop, and hip-hop. Always digging for the next hidden gem and rarely satisfied with whatever's on the radio.",
  },
  {
    label: 'Psychology',
    body: "Degree in it, never stopped thinking about it. Understanding how people think is the most underrated skill in IT — and probably everywhere else.",
  },
];
---

<BaseLayout
  title="About"
  description="Who Ben Atkins is — IT by day, curious about everything else."
  orbColor="rgba(37, 99, 235, 0.15)"
>
  <header class="mb-12">
    <h1
      class="text-4xl font-bold mb-3"
      style="font-family: var(--font-display); color: var(--color-heading);"
    >
      About
    </h1>
    <p style="color: var(--color-muted);">The longer version.</p>
  </header>

  <!-- Stats row -->
  <div class="grid grid-cols-3 gap-4 mb-12">
    {[
      { value: '6+', label: 'Years in IT' },
      { value: '900+', label: 'Users Supported' },
      { value: '50+', label: 'Facilities Served' },
    ].map(({ value, label }) => (
      <div
        class="rounded-lg p-4 text-center"
        style="background: var(--color-surface); border: 1px solid var(--color-border);"
      >
        <div
          class="text-3xl font-bold mb-1"
          style="font-family: var(--font-display); color: var(--color-accent-light);"
        >
          {value}
        </div>
        <div class="text-xs uppercase tracking-widest" style="color: var(--color-muted);">
          {label}
        </div>
      </div>
    ))}
  </div>

  <div class="flex flex-col gap-10" style="color: var(--color-body);">

    <!-- Career -->
    <section class="pl-5" style="border-left: 2px solid var(--color-accent);">
      <h2
        class="text-xs font-medium uppercase tracking-widest mb-4"
        style="color: var(--color-muted);"
      >
        Career
      </h2>
      <p class="leading-relaxed mb-3">
        Six years across healthcare and financial services — Vanderbilt Medical Center and LBMC.
        I've owned onboarding for 900 users, covered 50+ facilities across Middle Tennessee,
        led an O365 migration, built PowerShell automations, and coordinated SOC 2 audits.
        Now building toward DevOps.
      </p>
      <div class="flex flex-wrap gap-2 mb-4">
        {skills.map((skill) => (
          <span
            class="text-xs px-3 py-1 rounded-full"
            style="background: rgba(37, 99, 235, 0.12); color: var(--color-accent-light); border: 1px solid rgba(37, 99, 235, 0.25);"
          >
            {skill}
          </span>
        ))}
      </div>
      <a href="/career" class="text-sm text-[#60a5fa] underline hover:text-[#2563eb] transition-colors duration-200">
        Full career details →
      </a>
    </section>

    <!-- Background -->
    <section class="pl-5" style="border-left: 2px solid var(--color-accent);">
      <h2
        class="text-xs font-medium uppercase tracking-widest mb-4"
        style="color: var(--color-muted);"
      >
        Background
      </h2>
      <p class="leading-relaxed mb-3">
        Nashville native. Psychology degree from UT, started in healthcare working directly with
        patients and staff. Got hooked on the technical side — how systems worked, how they
        could be better — and committed to the switch.
      </p>
      <p class="leading-relaxed mb-3">
        Studied Python and web development at Red Rocks Community College, then moved back to
        Nashville for Nashville Software School's bootcamp (first cohort for the UI/UX emphasis).
        Went straight into enterprise IT and haven't looked back.
      </p>
      <p class="leading-relaxed">
        The psychology background wasn't a detour — it's why I'm good at this. Understanding
        people makes you better at supporting them.
      </p>
    </section>

    <!-- Passions -->
    <section class="pl-5" style="border-left: 2px solid var(--color-accent);">
      <h2
        class="text-xs font-medium uppercase tracking-widest mb-4"
        style="color: var(--color-muted);"
      >
        Passions
      </h2>
      <div class="grid gap-4 sm:grid-cols-3">
        {passions.map(({ label, body }) => (
          <div
            class="rounded-lg p-4"
            style="background: var(--color-surface); border: 1px solid var(--color-border);"
          >
            <div
              class="text-xs font-medium uppercase tracking-widest mb-2"
              style="color: var(--color-accent-light);"
            >
              {label}
            </div>
            <p class="text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="pt-2 border-t border-[#2a2a2a]">
      <div class="flex gap-5 text-sm" style="color: var(--color-muted);">
        <a
          href="https://github.com/Batkins44"
          target="_blank"
          rel="noopener noreferrer"
          class="py-2 hover:text-[#60a5fa] transition-colors duration-200"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/batkins44"
          target="_blank"
          rel="noopener noreferrer"
          class="py-2 hover:text-[#60a5fa] transition-colors duration-200"
        >
          LinkedIn
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
