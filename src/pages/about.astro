---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  'Identity & Access Management',
  'M365 / Azure',
  'Endpoint Management',
  'PowerShell',
  'SOC 2',
  'Hardware Deployment',
  'Front-End Dev',
];

const passions = [
  {
    label: 'Gaming',
    body: 'Souls-likes, Metroidvanias, JRPGs — and Rocket League perpetually in the background. Genuinely passionate about game design, mechanical innovation, and clean UX.',
  },
  {
    label: 'Music',
    body: "Indie rock, pop, and hip-hop. Always digging for the next hidden gem and rarely satisfied with whatever's on the radio.",
  },
  {
    label: 'Fantasy Football',
    body: 'Fiercely competitive manager with a borderline unhealthy level of investment and a well-documented imperviousness to annual heartbreak.',
  },
];
---

<BaseLayout
  title="About"
  description="Who Ben Atkins is — IT by day, curious about everything else."
  orbColor="rgba(37, 99, 235, 0.15)"
>
  <header class="mb-12">
    <h1
      class="text-4xl font-bold mb-3"
      style="font-family: var(--font-display); color: var(--color-heading);"
    >
      About
    </h1>
    <p style="color: var(--color-muted);">The longer version.</p>
  </header>

  <!-- Stats row -->
  <div class="grid grid-cols-3 gap-4 mb-12">
    {[
      { value: '6', label: 'Years in IT' },
      { value: '2', label: 'Industries' },
      { value: 'NSS', label: 'Bootcamp Grad' },
    ].map(({ value, label }) => (
      <div
        class="rounded-lg p-4 text-center"
        style="background: var(--color-surface); border: 1px solid var(--color-border);"
      >
        <div
          class="text-3xl font-bold mb-1"
          style="font-family: var(--font-display); color: var(--color-accent-light);"
        >
          {value}
        </div>
        <div class="text-xs uppercase tracking-widest" style="color: var(--color-muted);">
          {label}
        </div>
      </div>
    ))}
  </div>

  <div class="flex flex-col gap-10" style="color: var(--color-body);">

    <!-- Career -->
    <section class="pl-5" style="border-left: 2px solid var(--color-accent);">
      <h2
        class="text-xs font-medium uppercase tracking-widest mb-4"
        style="color: var(--color-muted);"
      >
        Career
      </h2>
      <p class="leading-relaxed mb-3">
        Six years of IT support and systems administration experience spanning healthcare (VUMC)
        and financial services (LBMC), with consistent delivery across varying compliance frameworks
        and operational demands.
      </p>
      <p class="leading-relaxed mb-6">
        Core competencies include identity and access management, M365/Azure administration,
        endpoint lifecycle management, hardware deployment, PowerShell automation, and SOC 2
        compliance coordination. Supplemental front-end development skills enable me to build
        solutions proactively, not just resolve issues reactively.
      </p>
      <div class="flex flex-wrap gap-2">
        {skills.map((skill) => (
          <span
            class="text-xs px-3 py-1 rounded-full"
            style="background: rgba(37, 99, 235, 0.12); color: var(--color-accent-light); border: 1px solid rgba(37, 99, 235, 0.25);"
          >
            {skill}
          </span>
        ))}
      </div>
    </section>

    <!-- Background -->
    <section class="pl-5" style="border-left: 2px solid var(--color-accent);">
      <h2
        class="text-xs font-medium uppercase tracking-widest mb-4"
        style="color: var(--color-muted);"
      >
        Background
      </h2>
      <p class="leading-relaxed mb-3">
        Nashville native. B.A. in Psychology with a minor in Business Administration from the
        University of Tennessee. Started my career in healthcare, where working directly with
        patients and staff built a strong foundation in communication and customer service.
      </p>
      <p class="leading-relaxed mb-3">
        While working in healthcare, I found myself increasingly drawn to the technical side of
        how systems worked and how they could be improved. Pondering a career change, I took
        courses in Python and web development at Red Rocks Community College.
      </p>
      <p class="leading-relaxed mb-3">
        Once I officially decided to pursue a career in tech, I moved back to Nashville and
        committed fully, completing Nashville Software School's full-stack web development bootcamp
        in 2017 with extensive training in JavaScript, React, and modern development practices.
      </p>
      <p class="leading-relaxed">
        Upon entering the IT field shortly after, each role has been a continuous education: new
        tools, new challenges, new ways to grow.
      </p>
    </section>

    <!-- Passions -->
    <section class="pl-5" style="border-left: 2px solid var(--color-accent);">
      <h2
        class="text-xs font-medium uppercase tracking-widest mb-4"
        style="color: var(--color-muted);"
      >
        Passions
      </h2>
      <div class="grid gap-4 sm:grid-cols-3">
        {passions.map(({ label, body }) => (
          <div
            class="rounded-lg p-4"
            style="background: var(--color-surface); border: 1px solid var(--color-border);"
          >
            <div
              class="text-xs font-medium uppercase tracking-widest mb-2"
              style="color: var(--color-accent-light);"
            >
              {label}
            </div>
            <p class="text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="pt-2 border-t border-[#2a2a2a]">
      <div class="flex gap-5 text-sm" style="color: var(--color-muted);">
        <a
          href="https://github.com/Batkins44"
          target="_blank"
          rel="noopener noreferrer"
          class="py-2 hover:text-[#60a5fa] transition-colors duration-200"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/batkins44"
          target="_blank"
          rel="noopener noreferrer"
          class="py-2 hover:text-[#60a5fa] transition-colors duration-200"
        >
          LinkedIn
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
