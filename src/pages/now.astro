---
import BaseLayout from '../layouts/BaseLayout.astro';

const lastUpdated = 'February 2026';

const games = [
  { name: 'Arc Raiders',   img: '/images/now/arc-raiders.jpg',   note: 'still deep in this one' },
  { name: 'Silksong',      img: '/images/now/silksong.jpg',      note: 'the wait is finally over' },
  { name: 'Rocket League', img: '/images/now/rocket-league.jpg', note: 'the eternal rotation' },
  { name: 'The First Berserker: Khazan', img: '/images/now/khazan.jpg', note: '' },
  { name: 'Brotato',       img: '/images/now/brotato.jpg',       note: 'perfect between-games game' },
  { name: 'Hades II',      img: '/images/now/hades2.jpg',       note: '' },
];

const shows = [
  { name: 'One Battle After Another', img: '/images/now/one-battle.jpg' },
  { name: 'Pluribus',                 img: '/images/now/pluribus.jpg' },
  { name: 'Fallout',                  img: '/images/now/fallout.jpg' },
  { name: 'What We Do in the Shadows', img: '/images/now/wwdits.png' },
];

const artists = [
  { name: 'Washed Out', img: '/images/now/washed-out.png' },
  { name: 'Panda Bear', img: '/images/now/panda-bear.png' },
  { name: 'MF DOOM',    img: '/images/now/mf-doom.png' },
  { name: 'Gorillaz',   img: '/images/now/gorillaz.png' },
];
---

<BaseLayout
  title="Now"
  description="What Ben Atkins is currently playing, watching, and thinking about."
  orbColor="rgba(236, 72, 153, 0.15)"
>
  <header class="mb-10">
    <h1
      class="text-4xl font-bold mb-3"
      style="font-family: var(--font-display); color: var(--color-heading);"
    >
      Now
    </h1>
    <p class="text-sm" style="color: var(--color-muted);">
      Last updated: {lastUpdated} &mdash;{' '}
      <a
        href="https://nownownow.com/about"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[#34d399] transition-colors duration-200 underline"
      >
        what's a now page?
      </a>
    </p>
  </header>

  <div class="flex flex-col gap-8" style="color: var(--color-body);">

    <!-- Playing -->
    <section>
      <h2
        class="text-xs font-medium uppercase tracking-widest mb-4 flex items-center gap-2"
        style="color: var(--color-muted);"
      >
        <span class="text-lg">🎮</span> Playing
      </h2>

      <!-- Highlight clip -->
      <div class="mb-4 relative overflow-hidden rounded-lg border border-[#2a2a2a]">
        <video
          autoplay
          muted
          loop
          playsinline
          class="w-full rounded-lg"
        >
          <source src="/images/now/best-goal.mp4" type="video/mp4" />
        </video>
        <div class="absolute bottom-0 left-0 right-0 px-3 py-2 bg-gradient-to-t from-black/80 to-transparent">
          <p class="text-xs font-medium text-[#34d399]" style="font-family: var(--font-display);">
            🚀 Recent highlight — Rocket League
          </p>
        </div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {games.map(game => (
          <div class="group relative overflow-hidden rounded-lg border border-[#2a2a2a] hover:border-[#059669] transition-all duration-300">
            <img
              src={game.img}
              alt={game.name}
              class="w-full aspect-[460/215] object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-3">
              <p
                class="text-sm font-semibold text-white leading-tight"
                style="font-family: var(--font-display);"
              >
                {game.name}
              </p>
              {game.note && (
                <p class="text-xs mt-0.5 text-[#34d399]">{game.note}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Watching -->
    <section>
      <h2
        class="text-xs font-medium uppercase tracking-widest mb-4 flex items-center gap-2"
        style="color: var(--color-muted);"
      >
        <span class="text-lg">📺</span> Watching
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {shows.map(show => (
          <div class="group relative overflow-hidden rounded-lg border border-[#2a2a2a] hover:border-[#059669] transition-all duration-300">
            <img
              src={show.img}
              alt={show.name}
              class="w-full aspect-[2/3] object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-3">
              <p
                class="text-sm font-semibold text-white leading-tight"
                style="font-family: var(--font-display);"
              >
                {show.name}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Listening -->
    <section>
      <h2
        class="text-xs font-medium uppercase tracking-widest mb-4 flex items-center gap-2"
        style="color: var(--color-muted);"
      >
        <span class="text-lg">🎧</span> Listening
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {artists.map(artist => (
          <div class="group relative overflow-hidden rounded-lg border border-[#2a2a2a] hover:border-[#059669] transition-all duration-300">
            <img
              src={artist.img}
              alt={artist.name}
              class="w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-3">
              <p
                class="text-sm font-semibold text-white leading-tight"
                style="font-family: var(--font-display);"
              >
                {artist.name}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
