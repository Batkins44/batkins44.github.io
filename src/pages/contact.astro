---
import BaseLayout from '../layouts/BaseLayout.astro';

const formspreeId = 'xqedbrqr';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Ben Atkins."
  orbColor="rgba(16, 185, 129, 0.15)"
>
  <header class="mb-10">
    <h1
      class="text-4xl font-bold mb-3"
      style="font-family: var(--font-display); color: var(--color-heading);"
    >
      Contact
    </h1>
    <p style="color: var(--color-muted);">
      I don't bite. Talk game design, fantasy sports, IT stuff, or whatever.
    </p>
  </header>

  <form
    id="contact-form"
    action={`https://formspree.io/f/${formspreeId}`}
    method="POST"
    class="flex flex-col gap-5 mb-12"
  >
    <div class="flex flex-col gap-1.5">
      <label
        for="name"
        class="text-xs font-medium uppercase tracking-widest"
        style="color: var(--color-muted);"
      >
        Name
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        placeholder="Your name"
        class="w-full rounded-lg px-4 py-3 text-sm border border-[#2a2a2a] bg-[#1a1a1a] focus:outline-none focus:border-[#059669] transition-colors duration-200"
        style="color: var(--color-body);"
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label
        for="email"
        class="text-xs font-medium uppercase tracking-widest"
        style="color: var(--color-muted);"
      >
        Email
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="your@email.com"
        class="w-full rounded-lg px-4 py-3 text-sm border border-[#2a2a2a] bg-[#1a1a1a] focus:outline-none focus:border-[#059669] transition-colors duration-200"
        style="color: var(--color-body);"
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label
        for="message"
        class="text-xs font-medium uppercase tracking-widest"
        style="color: var(--color-muted);"
      >
        Message
      </label>
      <textarea
        id="message"
        name="message"
        required
        rows="6"
        placeholder="What's on your mind?"
        class="w-full rounded-lg px-4 py-3 text-sm border border-[#2a2a2a] bg-[#1a1a1a] focus:outline-none focus:border-[#059669] transition-colors duration-200 resize-y"
        style="color: var(--color-body);"
      ></textarea>
    </div>

    <div id="form-error" class="hidden text-sm px-4 py-3 rounded-lg bg-red-900/30 border border-red-700 text-red-400">
      Something went wrong. Please try again or email me directly.
    </div>

    <button
      id="submit-btn"
      type="submit"
      class="self-start px-6 py-3 rounded-lg text-sm font-medium text-white transition-colors duration-200 cursor-pointer bg-[#059669] hover:bg-[#047857] disabled:opacity-50 disabled:cursor-not-allowed"
    >
      Send it
    </button>
  </form>

  <div id="form-success" class="hidden mb-12 px-4 py-3 rounded-lg bg-green-900/30 border border-green-700 text-green-400 text-sm">
    Got it — I'll get back to you soon.
  </div>

  <div class="pt-6 border-t border-[#2a2a2a]">
    <p class="text-sm mb-4" style="color: var(--color-muted);">Also here:</p>
    <div class="flex gap-5 text-sm">
      <a
        href="https://github.com/Batkins44"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[#34d399] transition-colors duration-200"
        style="color: var(--color-muted);"
      >
        GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/batkins44"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[#34d399] transition-colors duration-200"
        style="color: var(--color-muted);"
      >
        LinkedIn
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorMsg = document.getElementById('form-error') as HTMLDivElement;
  const successMsg = document.getElementById('form-success') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');

    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
      } else {
        throw new Error('Non-OK response');
      }
    } catch {
      errorMsg.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Send it';
    }
  });
</script>
