---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Gaming"
  description="Ben Atkins's gaming profile, reviews, and highlights."
  orbColor="rgba(99, 102, 241, 0.15)"
>
  <header class="mb-10">
    <h1
      class="text-4xl font-bold mb-3"
      style="font-family: var(--font-display); color: var(--color-heading);"
    >
      Gaming
    </h1>
    <p style="color: var(--color-muted);">
      Reviews, highlights, countdowns, and more — coming soon.
    </p>
  </header>

  <section>
    <h2
      class="text-xs font-medium uppercase tracking-widest mb-4"
      style="color: var(--color-muted);"
    >
      Find me on Steam
    </h2>
    <a
      href="https://steamcommunity.com/profiles/76561198025429665"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-4 p-5 rounded-xl border border-[#2a2a2a] hover:border-[#2563eb] transition-all duration-300 group"
      style="background: #1a1a1a;"
    >
      <!-- Steam logo SVG -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 233 233"
        class="w-10 h-10 shrink-0 transition-opacity duration-200 group-hover:opacity-100 opacity-60"
        aria-hidden="true"
      >
        <path
          fill="#ffffff"
          d="M116.5 0C52.1 0 0 52.1 0 116.5c0 55.5 38.8 102 90.9 113.8l33.5-82.5c-2.3.3-4.6.5-6.9.5-26.5 0-48-21.5-48-48s21.5-48 48-48 48 21.5 48 48c0 21.5-14.1 39.7-33.5 45.9l-32.7 80.6c3.4.1 6.8.2 10.2.2 64.4 0 116.5-52.1 116.5-116.5S180.9 0 116.5 0zM90.4 172.5l-14.3-5.9c2.5 5.2 6.3 9.8 11.3 13.1 11.5 7.5 26.4 6.4 36.7-2.1l-13.5-5.6c-6.3 3.2-13.8 3.2-20.2.5zm27.1-56.2c0 17.7-14.3 32-32 32s-32-14.3-32-32 14.3-32 32-32 32 14.3 32 32zm-32-24c-13.3 0-24 10.7-24 24s10.7 24 24 24 24-10.7 24-24-10.7-24-24-24z"
        />
      </svg>
      <div>
        <p class="font-semibold text-[#f5f5f5] group-hover:text-[#60a5fa] transition-colors duration-200" style="font-family: var(--font-display);">
          batkins4
        </p>
        <p class="text-sm mt-0.5" style="color: var(--color-muted);">
          View profile or send a friend request
        </p>
      </div>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4 ml-auto shrink-0 opacity-40 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-200"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        style="color: var(--color-muted);"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </section>
</BaseLayout>
